{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["node", "express", "cors", "multer"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist", "tests", "vitest.config.ts"]
}
