# Copy to .env and set at least one LLM API key for real AI features.
# Demo mode is automatic when no LLM key is set (or set LLM_PROVIDER=demo).

# --- LLM provider ---
# auto | openai | gemini | claude | demo
# With auto, priority is: claude → gemini → openai
# LLM_PROVIDER=auto

# Set ONE provider key (Gemini needs only GEMINI_API_KEY — no GCP project ID)

# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-haiku-4-5

# --- API server (optional) ---
# PORT=3001
# PUBLIC_URL=http://localhost:5173
# UPLOAD_DIR=./uploads
# SKILLS_DIR=

# --- Job search tuning (optional — defaults work; uncomment only to override) ---
# JOB_SEARCH_CONCURRENCY=4          # parallel board queries (default 4)
# JOB_SEARCH_RESULTS_PER_BOARD=8    # max listings per board (default 8)
# JOB_SEARCH_FETCH_TIMEOUT_MS=15000 # direct board HTML fetch timeout ms (default 15000)

# --- Docker Compose (optional) ---
# HOST_PORT=8080
# PUBLIC_URL=http://localhost:8080

# --- Vite dev proxy (optional, local npm run dev only) ---
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001
